{
  "name": "eleven-agent-cli",
  "version": "0.1.0",
  "description": "elv — agent-first ElevenLabs CLI: one JSON envelope per command over the ElevenLabs OpenAPI spec.",
  "type": "module",
  "bin": {
    "elv": "dist/cli.js"
  },
  "files": [
    "dist",
    "spec/openapi.snapshot.json",
    "AGENTS.md",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt src tests",
    "format:check": "oxfmt --check src tests"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^11",
    "ajv": "^8",
    "ajv-formats": "^3",
    "commander": "^14",
    "mime-types": "^2",
    "music-metadata": "^10",
    "ws": "^8"
  },
  "devDependencies": {
    "@types/mime-types": "^2",
    "@types/node": "^22",
    "@types/ws": "^8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true
  }
}
